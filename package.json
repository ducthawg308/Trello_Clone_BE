{
  "name": "nodejs-expressjs-mongodb-base-project",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "DucThangDev",
  "description": "Trello Clone Project",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf build && mkdir build",
    "build": "npm run clean && cp -r src build",
    "production": "npm run build && cross-env BUILD_MODE=production node ./build/src/server.js",
    "dev": "cross-env BUILD_MODE=dev nodemon ./src/server.js"
  },
  "dependencies": {
    "async-exit-hook": "^2.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "mongodb": "^7.1.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "nodemon": "^3.1.4"
  }
}
